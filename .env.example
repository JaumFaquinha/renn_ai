# =============================================================================
# Engenheiro de Corrida IA — Variáveis de Ambiente
# Copie para .env e preencha os valores reais. NUNCA comite o .env.
# =============================================================================

# === Supabase ===
# Habilitar integração (false por padrão — o projeto funciona 100% offline sem ele)
SUPABASE_ENABLED=false
# Settings → API → Project URL
SUPABASE_URL=https://xxxx.supabase.co
# Settings → API → service_role → Reveal (NUNCA usar anon key aqui)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# UUID fixo do piloto — gere com: py -3.11 -c "import uuid; print(uuid.uuid4())"
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000

# === Sessão e Gravação ===
# Diretório de saída das voltas em JSON (relativo à raiz do projeto)
LAPS_OUTPUT_DIR=data/laps

# Frequência de leitura da Shared Memory em Hz
# 20 = padrão e recomendado | 50 = alta resolução (maior uso de CPU)
SAMPLING_RATE_HZ=20

# === Validação de Volta ===
# Threshold de dano do carro para descarte de volta (0.0 a 1.0)
# 0.1 = até 10% de dano tolerado (recomendado)
# Nota: valores > 0.2 contaminam o modelo com física de carro danificado
CAR_DAMAGE_THRESHOLD=0.1

# Mínimo de mini-setores para a volta ser considerada válida
# 80 = ~80% da pista (ignora voltas muito curtas ou interrompidas)
MIN_SECTORS_PER_LAP=80

# === TTS — Fase 6 (voz do engenheiro) ===
# Provider: "none" | "pyttsx3" | "edge_tts" | "elevenlabs" | "azure"
#  - none       → apenas log textual (sem áudio)
#  - pyttsx3    → SAPI5 Windows, offline, ~150ms latência (pip install pyttsx3)
#  - edge_tts   → MS Edge neural voices, free sem chave, online (pip install edge-tts sounddevice soundfile)
#  - elevenlabs → premium Flash v2.5, ~75-200ms TTFB (pip install elevenlabs sounddevice soundfile)
#  - azure      → MS neural enterprise (pip install azure-cognitiveservices-speech)
TTS_PROVIDER=none

# Provider de fallback se o principal falhar (recomendado: pyttsx3)
TTS_FALLBACK=pyttsx3

# Idioma e voz (override opcional — default depende do provider)
# edge_tts PT-BR: pt-BR-AntonioNeural | pt-BR-FranciscaNeural | pt-BR-ThalitaNeural
# azure PT-BR: pt-BR-AntonioNeural | pt-BR-FranciscaNeural
# pyttsx3: nome parcial (ex: "Maria", "Daniel") — depende das vozes instaladas no Windows
TTS_LANGUAGE=pt-BR
TTS_VOICE_NAME=

# Cap de segurança (chars) — acima disto o corte é no fim da última frase
# completa, nunca no meio. 350 acomoda a mensagem mais rica (~280 chars) sem cortar.
TTS_MAX_MESSAGE_CHARS=350

# Cooldown entre alertas (segundos) — evita overlap auditivo
TTS_MIN_INTERVAL_S=3.0

# Ganho de volume do áudio TTS (edge_tts/elevenlabs). 1.0 = original, 2.0 = 2x.
# Clampeado em [-1,1]; valores altos (>3) podem distorcer.
TTS_VOLUME_GAIN=1.0

# ElevenLabs (preencher se TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Azure TTS (preencher se TTS_PROVIDER=azure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# === Logging ===
# DEBUG = detalhe total (desenvolvimento) | INFO = sessão normal | WARNING = silencioso
LOG_LEVEL=INFO
