# Engenheiro de Corrida IA — Variáveis de Ambiente
# Copie para .env e preencha os valores reais (nunca comite .env)

# === Fase 6: TTS Provider ===
# Escolha: "elevenlabs" | "azure" | "none"
TTS_PROVIDER=none

# ElevenLabs (se TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Azure TTS (se TTS_PROVIDER=azure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# === Fase 7: Supabase ===
# Habilitar integração com Supabase (false por padrão — projeto funciona sem ele)
SUPABASE_ENABLED=false
# URL do projeto Supabase: Settings → API → Project URL
SUPABASE_URL=https://xxxx.supabase.co
# service_role key (nunca usar anon key aqui): Settings → API → service_role → Reveal
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# UUID fixo do piloto — gere com: py -3.11 -c "import uuid; print(uuid.uuid4())"
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000

# === Configurações de Sessão ===
# Diretório de saída das voltas gravadas (relativo à raiz do projeto)
LAPS_OUTPUT_DIR=data/laps

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
